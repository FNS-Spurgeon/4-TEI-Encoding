  <text>
    <body>
      <head>A TEI Customization for Allusions to Chaucer</head>

      <p>This ODD selects required elements to encode allusions to Chaucer. We have chosen a minimal encoding that covers the widest possible range of cases.
        This document sets out the technical requirements. Details of the options, together with examples, are provided in a separate document.</p>
      
      <schemaSpec ident="tei_chaucerAllusions" start="TEI" prefix="tei_" targetLang="en"
        docLang="en">

        <!-- required minimal header elements -->
        <moduleRef key="header"
          include="teiHeader fileDesc titleStmt publicationStmt sourceDesc appInfo authority availability encodingDesc editorialDecl idno language langUsage licence profileDesc projectDesc revisionDesc samplingDecl textClass catRef application change"/>

        <!-- required core elements (p and title for use in titleStmt) -->
        <moduleRef key="core"
          include="p title add address addrLine analytic author biblScope biblStruct date graphic head hi imprint item l lb lg list monogr note milestone ptr publisher pubPlace resp respStmt label name"/>

        <!-- required textstructure elements (TEI, text, and body) -->
        <moduleRef key="textstructure" include="TEI text body div"/>

        <!-- required module tei instantiates lots of classes used for further expansion of this odd -->
        <moduleRef key="tei"/>

        <moduleRef key="figures" include="figure figDesc table row"/>
        
        <moduleRef key="linking" include="seg ab"/>
        
        <elementSpec ident="hi" mode="change">
          <attList>
            <attDef ident="rend" mode="change">
              <valList type="semi" mode="change">
                <valItem mode="add" ident="italic"/>
              </valList>
            </attDef>
          </attList>
        </elementSpec>
        <elementSpec ident="seg" mode="change">
          <attList>
            <attDef ident="type" mode="change">
              <valList mode="change">
                <valItem mode="add" ident="editorial"/>
              </valList>
            </attDef>
          </attList>
        </elementSpec>
        <elementSpec ident="ab" mode="change">
          <attList>
            <attDef ident="type" mode="change">
              <valList type="closed" mode="change">
                <valItem mode="add" ident="quotation"/>
                <valItem mode="add" ident="imprint"/>
              </valList>
            </attDef>
          </attList>
        </elementSpec>
        <classSpec ident="att.global.rendition" type="atts" mode="change">
          <attList>
            <attDef ident="rend" mode="change">
              <valList type="semi" mode="change"/>
            </attDef>
          </attList>
        </classSpec>
        <classRef key="att.datable.custom"/>
        <classRef key="att.global.linking"/>
        <classRef key="att.milestoneUnit"/>
        <classRef key="att.calendarSystem"/>
        <classSpec ident="att.anchoring" type="atts" mode="delete"/>
      </schemaSpec>
    </body>
  </text>
</TEI>
